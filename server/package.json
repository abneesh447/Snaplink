    "@types/node": "^20.11.24",
    "@types/supertest": "^6.0.2",
    "@types/ua-parser-js": "^0.7.39",
    "prisma": "^5.10.2",
    "supertest": "^6.3.4",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1"
  }
