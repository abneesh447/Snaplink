{
  "name": "url-shortener-server",
  "version": "1.0.0",
  "type": "module",
  "description": "Backend for URL Shortener using Node.js, Express, Prisma, and MongoDB",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "build": "echo 'No compilation needed for JS'",
